      <memberdef kind="function" id="vimscript_8c_1a2a83f66985ca8c9b3f68acf763628ca9" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void nvim_command</definition>
        <argsstring>(String command, Error *err) FUNC_API_SINCE(1)</argsstring>
        <name>nvim_command</name>
        <param>
          <type>String</type>
          <declname>command</declname>
        </param>
        <param>
          <type>Error *</type>
          <declname>err</declname>
        </param>
        <briefdescription>
        </briefdescription>
        <detaileddescription>
<para>Executes an Ex command.</para>
<para>On execution error: fails with Vimscript error, updates v:errmsg.</para>
<para>Prefer |nvim_cmd()| or |nvim_exec2()| instead. To modify an Ex command in a structured way before executing it, modify the result of |nvim_parse_cmd()| then pass it to |nvim_cmd()|.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>command</parametername>
</parameternamelist>
<parameterdescription>
<para>Ex command string </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">err</parametername>
</parameternamelist>
<parameterdescription>
<para>Error details (Vim error), if any </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
