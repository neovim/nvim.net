      <memberdef kind="function" id="autocmd_8c_1aa009687de5cee96e9bec049730e221cf" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void nvim_clear_autocmds</definition>
        <argsstring>(Dict(clear_autocmds) *opts, Arena *arena, Error *err) FUNC_API_SINCE(9)</argsstring>
        <name>nvim_clear_autocmds</name>
        <param>
          <type><ref refid="struct_dict" kindref="compound">Dict</ref>(clear_autocmds) *</type>
          <declname>opts</declname>
        </param>
        <param>
          <type>Arena *</type>
          <declname>arena</declname>
        </param>
        <param>
          <type>Error *</type>
          <declname>err</declname>
        </param>
        <briefdescription>
        </briefdescription>
        <detaileddescription>
<para>Clears all autocommands selected by {opts}. To delete autocmds see |nvim_del_autocmd()|.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>opts</parametername>
</parameternamelist>
<parameterdescription>
<para>Parameters<itemizedlist>
<listitem><para>event: (string|table) Examples:<itemizedlist>
<listitem><para>event: &quot;pat1&quot;</para>
</listitem><listitem><para>event: { &quot;pat1&quot; }</para>
</listitem><listitem><para>event: { &quot;pat1&quot;, &quot;pat2&quot;, &quot;pat3&quot; }</para>
</listitem></itemizedlist>
</para>
</listitem><listitem><para>pattern: (string|table)<itemizedlist>
<listitem><para>pattern or patterns to match exactly.<itemizedlist>
<listitem><para>For example, if you have <computeroutput>*.py</computeroutput> as that pattern for the autocmd, you must pass <computeroutput>*.py</computeroutput> exactly to clear it. <computeroutput>test.py</computeroutput> will not match the pattern.</para>
</listitem></itemizedlist>
</para>
</listitem><listitem><para>defaults to clearing all patterns.</para>
</listitem><listitem><para>NOTE: Cannot be used with {buffer}</para>
</listitem></itemizedlist>
</para>
</listitem><listitem><para>buffer: (bufnr)<itemizedlist>
<listitem><para>clear only |autocmd-buflocal| autocommands.</para>
</listitem><listitem><para>NOTE: Cannot be used with {pattern}</para>
</listitem></itemizedlist>
</para>
</listitem><listitem><para>group: (string|int) The augroup name or id.<itemizedlist>
<listitem><para>NOTE: If not passed, will only delete autocmds <emphasis>not</emphasis> in any group. </para>
</listitem></itemizedlist>
</para>
</listitem></itemizedlist>
</para>
</parameterdescription>
</parameteritem>
</parameterlist>
